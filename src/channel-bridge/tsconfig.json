{
    "compilerOptions": {
        "strict": true,
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "../../dist-channel-bridge",
        "rootDir": ".",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "incremental": true,
        "tsBuildInfoFile": "../../dist-channel-bridge/.tsbuildinfo"
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules", "./**/*.test.ts"]
}
