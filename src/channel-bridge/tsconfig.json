{
    "compilerOptions": {
        "strict": true,
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "../../dist-channel-bridge",
        "rootDir": ".",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "declaration": true,
