{
  "name": "xpdite",
  "private": true,
  "version": "0.0.0",
  "description": "AI-powered desktop assistant with Electron, React, and Python",
  "author": "Kashyap Tanuku",
  "type": "module",
  "main": "dist-electron/main.js",
  "overrides": {
    "keyv": "^5.6.0"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron dev:ollama",
    "dev:react": "vite",
    "dev:electron": "bun run transpile:electron && cross-env NODE_ENV=development electron .",
    "dev:pyserver": "uv run python -m source.main",
    "dev:ollama": "node scripts/start-ollama.mjs",
    "test:ollama": "curl http://localhost:11434/api/tags",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:coverage": "vitest run --coverage",
    "build": "bun run build:icons && bun run build:python-exe && bun run build:python-runtime && bun run build:runtime-env && bun run build:channel-bridge && bun run transpile:electron && bun run build:react",
    "build:react": "vite build",
    "build:python": "node scripts/build-python.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build:python-exe": "uv run python scripts/build-python-exe.py",
    "build:python-runtime": "node scripts/build-python-runtime.mjs",
    "build:runtime-env": "node scripts/build-runtime-env.mjs",
    "build:channel-bridge": "tsc --project src/channel-bridge/tsconfig.json --noEmit && node scripts/build-channel-bridge.mjs",
    "prepack": "bun run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "transpile:electron": "tsc --project src/electron/tsconfig.json",
    "install:python": "uv sync --group dev",
    "install:uv": "powershell -ExecutionPolicy ByPass -c \"irm https://astral.sh/uv/install.ps1 | iex\"",
    "dist:mac": "node scripts/run-electron-dist.mjs mac arm64",
    "dist:linux": "node scripts/run-electron-dist.mjs linux x64",
    "dist:win": "node scripts/run-electron-dist.mjs win x64",
    "dist": "bun run dist:win"
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.20.2",
    "@chat-adapter/state-memory": "^4.20.2",
    "@chat-adapter/telegram": "^4.20.2",
    "@chenglou/pretext": "^0.0.4",
    "@types/react-router-dom": "^5.3.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "baileys": "^7.0.0-rc.9",
    "chat": "^4.20.2",
    "chat-adapter-baileys": "^1.1.0",
    "playwright": "^1.58.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-syntax-highlighter": "^15.6.6",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.0.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "electron-builder-squirrel-windows": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^29.0.1",
    "lightningcss": "^1.32.0",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.0"
  }
}
