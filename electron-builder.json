{
    "appId": "com.kashyap-tanuku.xpdite",
    "productName": "Xpdite",
    "copyright": "Copyright © 2025 Kashyap Tanuku",
    "files": [
        "dist-electron", 
        "dist-react"
    ],
    "extraResources": [
        {
            "from": "dist-python/xpdite-server",
            "to": "python-server",
            "filter": [
                "**/*"
            ]
        },
        {
            "from": "dist-python-runtime",
            "to": "python-runtime",
            "filter": [
                "**/*"
            ]
        },
        {
            "from": "dist-channel-bridge",
            "to": "channel-bridge",
            "filter": [
                "**/*"
            ]
        },
        {
            "from": "dist-runtime-config",
            "to": "runtime-config",
            "filter": [
                "**/*"
            ]
        }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "./assets/xpdite-icon.png",
    "mac": {
        "target": "dmg",
        "icon": "./assets/xpdite.icns"
    },
    "linux": {
        "target": "AppImage",
        "category": "Utility",
        "icon": "./assets/xpdite-icon.png"
    },
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": ["x64"]
            }
        ],
        "icon": "./assets/xpdite.ico"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true
    }
}
